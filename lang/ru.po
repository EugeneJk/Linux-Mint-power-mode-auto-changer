#: cli.cpp:44
msgid "Press Enter to close this window..."
msgstr "Нажмите Enter, чтобы закрыть окно..."

#: cli/actions/configure.cpp:23 cli/actions/help.cpp:8
msgid "Power Mode Auto Changer"
msgstr "Автопереключатель режимов питания"

#: cli/actions/configure.cpp:24
msgid "Interactive configuration mode"
msgstr "Режим интерактивной настройки"

#: cli/actions/configure.cpp:32 cli/actions/status.cpp:26
msgid "AC power source not detected. Unable to determine power state. Exiting."
msgstr ""
"Источник питания AC не обнаружен. Невозможно определить состояние питания. "
"Завершение работы."

#: cli/actions/configure.cpp:40 cli/actions/configure.cpp:74
msgid "Select the power mode when running"
msgstr "Выберите режим питания при работе"

#: cli/actions/configure.cpp:40
msgid "on AC power"
msgstr "от сети"

#: cli/actions/configure.cpp:44 cli/actions/configure.cpp:78
#: cli/actions/configure.cpp:113
msgid "Quit"
msgstr "Выход"

#: cli/actions/configure.cpp:48 cli/actions/configure.cpp:82
msgid "Enter choice"
msgstr "Выберите вариант"

#: cli/actions/configure.cpp:66 cli/actions/configure.cpp:100
msgid "Mode selected"
msgstr "Выбранный режим питания"

#: cli/actions/configure.cpp:67 cli/actions/configure.cpp:101
msgid "Enter notification text shown when this mode is activated"
msgstr "Введите текст уведомления при активации этого режима питания"

#: cli/actions/configure.cpp:68 cli/actions/configure.cpp:102
msgid "Press Enter to use the default value."
msgstr "Нажмите Enter для использования значения по умолчанию."

#: cli/actions/configure.cpp:69 cli/actions/configure.cpp:103
#: cli/actions/status.cpp:55 cli/actions/status.cpp:70
msgid "Notification text"
msgstr "Текст уведомления"

#: cli/actions/configure.cpp:74
msgid "on battery power"
msgstr "от батареи"

#: cli/actions/configure.cpp:108
msgid "Enable power mode synchronization at system startup?"
msgstr "Включить синхронизацию режима питания при загрузке системы?"

#: cli/actions/configure.cpp:113
msgid "Yes"
msgstr "Да"

#: cli/actions/configure.cpp:113
msgid "No"
msgstr "Нет"

#: cli/actions/configure.cpp:139
msgid "Can't create config folder"
msgstr "Невозможно создать каталог с настройками"

#: cli/actions/configure.cpp:146
msgid "Can't save user configuration file"
msgstr "Невозможно сохранить файл с пользовательскими настройками"

#: cli/actions/configure.cpp:154
msgid "Configuration saved successfully."
msgstr "Настройки сохранены."

#: cli/actions/help.cpp:9
msgid "Usage"
msgstr "Использование"

#: cli/actions/help.cpp:12
msgid "Actions"
msgstr "Действия"

#: cli/actions/help.cpp:13
msgid "Show current service and power mode status."
msgstr "Показать текущее состояние сервиса и режима питания."

#: cli/actions/help.cpp:14
msgid "Run interactive configuration."
msgstr "Запустить интерактивную настройку."

#: cli/actions/help.cpp:15
msgid "Show this help message (default)."
msgstr "Показать справку (по умолчанию)."

#: cli/actions/help.cpp:16
msgid "Show program version."
msgstr "Показать версию программы."

#: cli/actions/help.cpp:18
msgid "Options"
msgstr "Параметры"

#: cli/actions/help.cpp:19
msgid "Force Russian language."
msgstr "Принудительно использовать русский язык."

#: cli/actions/help.cpp:20
msgid "Force English language."
msgstr "Принудительно использовать английский язык."

#: cli/actions/help.cpp:21
msgid "Enable exit confirmation when launched from the desktop menu."
msgstr "Добавить подтверждение выхода из программы при запуске из меню."

#: cli/actions/help.cpp:23
msgid "Examples"
msgstr "Примеры"

#: cli/actions/help.cpp:31
msgid "Notes"
msgstr "Примечания"

#: cli/actions/help.cpp:32
msgid "Only one action may be specified."
msgstr "Можно указать только одно действие."

#: cli/actions/help.cpp:33
msgid "If no action is specified, --help is used by default."
msgstr "Если действие не указано, используется --help."

#: cli/actions/help.cpp:34
msgid "Configuration is interactive."
msgstr "Настройка выполняется в интерактивном режиме."

#: cli/actions/status.cpp:41
msgid "Enabled"
msgstr "Включено"

#: cli/actions/status.cpp:41
msgid "Disabled"
msgstr "Выключено"

#: cli/actions/status.cpp:43
msgid "Power mode synchronization on startup"
msgstr "Синхронизация режима питания при загрузке"

#: cli/actions/status.cpp:51
msgid "Power mode when connected to AC"
msgstr "Режим питания при подключенном источнике питания"

#: cli/actions/status.cpp:66
msgid "Power mode when running on battery"
msgstr "Режим питания при работе от батареи"

#: cli/actions/status.cpp:77
msgid ""
"Application is not configured. Run the configurator to set it up. Exiting."
msgstr ""
"Приложение не сконфигурировано. Запустите конфигуратор. Завершение работы."

#: cli/actions/version.cpp:13
msgid "Version"
msgstr "Версия"

#: cli/parse-args.cpp:21
msgid "Unknown action"
msgstr "Неизвестное действие"

#: cli/parse-args.cpp:36
msgid "Unknown parameter"
msgstr "Неизвестный параметер"

#: cli/parse-args.cpp:49
msgid "Only one action supported"
msgstr "Только одно действие допустимо"

#: common/user-config.cpp:53
msgid "Power saver"
msgstr "Энергосбережение"

#: common/user-config.cpp:55
msgid "Balanced"
msgstr "Сбалансировано"

#: common/user-config.cpp:57
msgid "Performance"
msgstr "Быстродействие"

