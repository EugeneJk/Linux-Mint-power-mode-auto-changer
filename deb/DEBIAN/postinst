#!/bin/bash
set -e

CONFIG_DIR="/etc/power-mode-auto-changer"
CONFIG_FILE="$CONFIG_DIR/config"

mkdir -p "$CONFIG_DIR"

# Find path to check AC status
AC_PATH=$(for d in /sys/class/power_supply/*; do
    if [ "$(cat "$d/type" 2>/dev/null)" = "Mains" ]; then
        echo "$d/online"
        break
    fi
done)

# Check if performance profile is available
IS_PERFORMANCE_AVAILABLE=0

if command -v powerprofilesctl >/dev/null 2>&1; then
    if powerprofilesctl list 2>/dev/null | grep -q "performance"; then
        IS_PERFORMANCE_AVAILABLE=1
    fi
fi

cat <<EOF > "$CONFIG_FILE"
# Power Mode Auto Changer configuration

AC_PATH=$AC_PATH
IS_PERFORMANCE_AVAILABLE=$IS_PERFORMANCE_AVAILABLE
EOF

systemctl daemon-reload
udevadm control --reload

exit 0